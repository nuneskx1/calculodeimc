@model calculodeimc.Models.ImcViewModel

@{
    ViewData["Title"] = "Calculadora de IMC";
}

    <div class="container mt-5">
        <div class="row justify-content-center">
        <div class="col-md-6">
        <div class="card shadow">
        <div class="card-header bg-primary text-white">
        <h3 class="card-title text-center mb-0">Calculadora de IMC</h3>
    </div>

    <div class="card-body">
    <form asp-action="Index" method="post">
                        
    <div class="mb-3">
        <label asp-for="Peso" class="form-label">Peso (kg):</label>
        <input asp-for="Peso" class="form-control" type="number" step="0.01" placeholder="Ex: 75.5" />
        <span asp-validation-for="Peso" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Altura" class="form-label">Altura (m):</label>
        <input asp-for="Altura" class="form-control" type="number" step="0.01" placeholder="Ex: 1.75" />
        <span asp-validation-for="Altura" class="text-danger"></span>
    </div>

        <button type="submit" class="btn btn-primary w-100">Calcular IMC</button>
    </form>

@if (Model.ResultadoImc.HasValue)
{
    <div class="alert alert-info mt-4 text-center">
        <h5>Seu IMC é: <strong>@Model.ResultadoImc.Value.ToString("F2")</strong></h5>
        <p class="mb-0">Classificação: <strong>@Model.Classificacao</strong></p>
    </div>}
    </div>
    </div>
    </div>
    </div>
    </div>